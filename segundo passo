from pynput import keyboard
from datetime import datetime

ARQUIVO = "log_teclas.txt"

def salvar(texto):
    with open(ARQUIVO, "a", encoding="utf-8") as f:
        f.write(texto)

def ao_pressionar(tecla):
    try:
        registro = f"{datetime.now()} - {tecla.char}\n"
    except AttributeError:
        registro = f"{datetime.now()} - [{tecla}]\n"

    print(registro.strip())  # Transparente (mostra na tela)
    salvar(registro)

def ao_soltar(tecla):
    if tecla == keyboard.Key.esc:
        print("Encerrando captura.")
        return False

print("Captura iniciada (pressione ESC para sair)...")

with keyboard.Listener(on_press=ao_pressionar, on_release=ao_soltar) as listener:
    listener.join()
